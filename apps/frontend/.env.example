# API Base URL - browser + server default
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public URLs for media (clipboard / Next/Image). Match the site users open (e.g. https://cms.brainspark.app).
# Next rewrites GET /media/public/* → NEXT_PUBLIC_API_URL (or MEDIA_PROXY_TARGET) so files load via the CMS host.
NEXT_PUBLIC_MEDIA_BASE_URL=https://cms.brainspark.app

# Optional: internal API URL for media rewrites only (Docker service name). Defaults to NEXT_PUBLIC_API_URL.
# MEDIA_PROXY_TARGET=http://backend:3001
