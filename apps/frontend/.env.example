# API Base URL - browser + server default
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: server-only URL for landing fetches (Docker: http://backend:3001)
# LANDING_API_URL=http://backend:3001
# Optional: public site tenant when not using subdomain / session (must match tenant.slug in DB)
# NEXT_PUBLIC_LANDING_TENANT_SLUG=my-org
