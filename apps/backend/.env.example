MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<db>?retryWrites=true&w=majority
JWT_SECRET=change_me_to_a_strong_random_secret
PORT=3001
FRONTEND_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_admin_chat_id
# Set to true if Telegram API is blocked or slow (dev/VPN); skips polling/webhook launch so the backend still starts.
TELEGRAM_SKIP_LAUNCH=true
MINIO_ENDPOINT=http://your-minio-host:9002
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123

# Media library: enable one or both providers (dashboard can switch at runtime when both are true).
MEDIA_PROVIDER_MINIO_ENABLED=true
MEDIA_PROVIDER_LOCAL_ENABLED=false
# Directory for local provider uploads (created automatically).
LOCAL_MEDIA_ROOT=./uploads/media
# Public base URLs used in API responses (absolute links for blogs / Next.js image src).
# You can set PUBLIC_MEDIA_BASE_URL as a single fallback for both providers.
PUBLIC_MEDIA_BASE_URL_MINIO=https://your-cdn-or-gateway.example.com
# Local disk: use your CMS origin when Next.js proxies /media/public/* to this API (e.g. https://cms.brainspark.app).
PUBLIC_MEDIA_BASE_URL_LOCAL=https://cms.brainspark.app

# Image upload optimization (Sharp). SVG and GIF are stored as-is (GIF keeps animation).
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_MAX_EDGE=2560
# webp (default) or jpeg
IMAGE_OUTPUT_FORMAT=webp
IMAGE_WEBP_QUALITY=82
IMAGE_JPEG_QUALITY=85
# Max multipart file size per upload (bytes). Default ~15 MB.
MEDIA_MAX_UPLOAD_BYTES=15728640

# LeadSpark AI integration
LEADSPARK_PROJECT_REF=your_project_ref
LEADSPARK_API_KEY=your_external_products_api_key
LEADSPARK_ORGANIZATION_ID=your_org_uuid
